# .envrc

# 1. 檢查並自動安裝 uv
if ! command -v uv &> /dev/null; then
    log_status "未偵測到 uv，正在自動安裝..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
    # 將 uv 的預設安裝路徑加入 PATH，確保後續指令能找到它
    export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
fi

# 2. 確保虛擬環境存在 (uv 會自動處理 Python 的下載與安裝)
# 這裡指定使用 Python 3.12，若系統沒有，uv 會自動下載獨立的 Python 版本
if [ ! -d ".venv" ]; then
    log_status "未偵測到虛擬環境，正在使用 uv 建立 Python 3.12 環境..."
    uv venv --python 3.12 .venv
fi

# 3. 載入虛擬環境 (符合 direnv 最佳實踐，取代 source activate)
export VIRTUAL_ENV="$(pwd)/.venv"
PATH_add "$VIRTUAL_ENV/bin"

# 4. 檢查並自動安裝 ansible 與 ansible-core
# 因為前面已經 PATH_add，這裡會優先檢查虛擬環境內是否有 ansible
if ! command -v ansible &> /dev/null; then
    log_status "未偵測到 Ansible，正在透過 uv 極速安裝..."
    # uv pip 會自動偵測 VIRTUAL_ENV 並將套件安裝到 .venv 中
    uv pip install ansible ansible-core
fi

log_status "✅ 環境準備就緒！(uv, Python, Ansible 已就位)"

